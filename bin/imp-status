#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

repo=$(basename "$(git rev-parse --show-toplevel)")
branch=$(git branch --show-current)
tag=$(last_tag)

header "$repo"

label "Branch"
item "$branch"
echo

changes=$(git status --short)
if [[ -n "$changes" ]]; then
   # Batch numstats into a newline-delimited lookup string (Bash 3.2 compatible)
   numstats=""
   while read -r added removed file; do
      [[ -n "$file" ]] && numstats="${numstats}${file}	${added} ${removed}"$'\n'
   done < <(git diff --numstat 2> /dev/null || true)
   while read -r added removed file; do
      [[ -n "$file" ]] && numstats="${numstats}${file}	${added} ${removed}"$'\n'
   done < <(git diff --cached --numstat 2> /dev/null || true)

   label "Changes"
   while IFS= read -r line; do
      status="${line:0:2}"
      file="${line:3}"

      stats=""
      match=$(echo "$numstats" | grep -F "${file}	" | tail -1 || true)
      if [[ -n "$match" ]]; then
         nums="${match#*	}"
         added="${nums%% *}"
         removed="${nums##* }"
         stats=" ${GREEN}+${added}${RESET} ${RED}-${removed}${RESET}"
      fi

      case "$status" in
         " M" | "MM") echo -e "  ${YELLOW}M${RESET}  ${file}${stats}" ;;
         "M ") echo -e "  ${GREEN}M${RESET}  ${file}${stats}" ;;
         " D" | "D ") echo -e "  ${RED}D${RESET}  ${file}" ;;
         "A " | "AM") echo -e "  ${GREEN}A${RESET}  ${file}${stats}" ;;
         "R "* | "RM"*) echo -e "  ${CYAN}R${RESET}  ${file}" ;;
         "??") echo -e "  ${MUTED}?${RESET}  ${file}" ;;
         *) echo -e "  ${status}  ${file}${stats}" ;;
      esac
   done <<< "$changes"
   echo
fi

if [[ -n "$tag" ]]; then
   unpushed=$(git log --oneline "$tag..HEAD" 2> /dev/null || true)
else
   unpushed=$(git log --oneline -10 2> /dev/null || true)
fi

if [[ -n "$unpushed" ]]; then
   count=$(echo "$unpushed" | wc -l | tr -d ' ')
   show_items "Commits since ${tag:-start} ($count)" "$unpushed"
fi

worktrees=$(git worktree list 2> /dev/null)
wt_count=$(echo "$worktrees" | wc -l | tr -d ' ')

if [[ $wt_count -gt 1 ]]; then
   label "Worktrees"
   echo "$worktrees" | while read -r line; do
      if [[ "$line" == "$(pwd) "* ]]; then
         item "$line (here)"
      else
         item "$line"
      fi
   done
   echo
fi

if [[ -n "$tag" ]]; then
   muted "Last release: $tag"
fi

if [[ -n "$changes" ]]; then
   hint "git add <files>, then imp commit"
elif [[ -n "$unpushed" ]]; then
   hint "imp release to ship"
else
   hint "make changes, then imp commit"
fi
