#!/bin/bash
set -euo pipefail

IMP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
IMP_VERSION="0.0.7"

BOLD='\033[1m'
MUTED='\033[0;90m'
RESET='\033[0m'

usage() {
   echo
   echo -e "${BOLD}imp${RESET} v${IMP_VERSION} — AI-powered git workflow"
   echo
   echo "Usage: imp <command>"
   echo
   echo -e "${MUTED}Daily workflow${RESET}"
   echo "  commit     Generate commit message (-a to stage all)"
   echo "  split      Split changes into multiple commits"
   echo "  amend      Amend last commit with new message"
   echo "  undo       Undo last N commits (keeps changes staged)"
   echo "  revert     Safely undo a pushed commit"
   echo "  sync       Pull, rebase, push"
   echo
   echo -e "${MUTED}Branching${RESET}"
   echo "  branch     Create or switch branches"
   echo "  fix        Create branch from GitHub issue"
   echo "  pr         Create pull request"
   echo "  done       Clean up after PR merge"
   echo "  clean      Delete merged branches"
   echo
   echo -e "${MUTED}Analysis${RESET}"
   echo "  review     AI code review of changes"
   echo "  status     Show repo overview"
   echo "  log        Pretty commit graph"
   echo
   echo -e "${MUTED}Release${RESET}"
   echo "  release    Squash, changelog, tag, and push"
   echo
   echo -e "${MUTED}Help${RESET}"
   echo "  help       Show workflow guide"
   echo "  doctor     Check dependencies"
   echo
}

cmd="${1:-}"

[[ -z "$cmd" ]] && {
   usage
   exit 0
}

case "$cmd" in
   --version | -v | version)
      echo "imp $IMP_VERSION"
      exit 0
      ;;
   --help | -h)
      usage
      exit 0
      ;;
esac

script="$IMP_ROOT/bin/imp-$cmd"

if [[ -x "$script" ]]; then
   shift
   exec "$script" "$@"
else
   echo "Unknown command: $cmd" >&2
   usage
   exit 1
fi
