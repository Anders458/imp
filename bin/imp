#!/bin/bash
set -euo pipefail

IMP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
   cat << EOF
Usage: imp <command> [args]

Commands:
   commit      Generate commit message from staged changes
   release     Squash, changelog, tag, and push a release
   branch      Create branch from description
   describe    Explain what a branch does
   list        Show current work overview

Config (env vars):
   IMP_AI_PROVIDER    claude, ollama (default: claude)
   IMP_AI_MODEL_FAST  model for quick tasks (default: haiku)
   IMP_AI_MODEL_SMART model for complex tasks (default: sonnet)
EOF
}

cmd="${1:-}"

[[ -z "$cmd" ]] && {
   usage
   exit 0
}

script="$IMP_ROOT/bin/imp-$cmd"

if [[ -x "$script" ]]; then
   shift
   exec "$script" "$@"
else
   echo "Unknown command: $cmd" >&2
   echo
   usage
   exit 1
fi
