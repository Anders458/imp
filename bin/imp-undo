#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Undo"

if ! git rev-parse HEAD &> /dev/null; then
   muted "No commits to undo"
   exit 0
fi

count="${1:-1}"

if ! [[ "$count" =~ ^[0-9]+$ ]]; then
   err "Invalid count: $count"
   hint "imp undo [count]"
   exit 1
fi

total=$(commit_count)
if [[ "$count" -gt "$total" ]]; then
   err "Only $total commits available"
   exit 1
fi

show_items "Commits to undo" "$(git log --oneline -n "$count")"

if has_upstream; then
   ahead=$(count_ahead)
   if [[ "$count" -gt "$ahead" ]]; then
      warn "Some commits are already pushed"
      echo
   fi
fi

if ! confirm "Undo $count commit(s)? (changes stay staged)" "n"; then
   muted "Cancelled"
   exit 0
fi

git reset --soft "HEAD~$count"

success "Undone $count commit(s)"
hint "imp commit to recommit, or keep editing"
