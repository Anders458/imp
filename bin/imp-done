#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Done"

branch=$(git branch --show-current)
base=$(base_branch)

if [[ "$branch" == "$base" ]]; then
   err "Already on $base"
   hint "switch to a feature branch first"
   exit 1
fi

require_clean

label "Switching"
item "$branch → $base"
echo

git checkout "$base"

if has_upstream; then
   git pull
fi

if git branch -d "$branch" 2> /dev/null; then
   success "Deleted local branch $branch"
else
   warn "Branch $branch has unmerged changes"
   echo
   if confirm "Force delete $branch?" "n"; then
      git branch -D "$branch"
      success "Force deleted local branch $branch"
   else
      muted "Kept local branch $branch"
   fi
fi

if git ls-remote --heads origin "$branch" 2> /dev/null | grep -q "$branch"; then
   git push origin --delete "$branch"
   success "Deleted remote branch $branch"
fi

echo
hint "imp branch to start something new"
