#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

desc="$*"

if [[ -z "$desc" ]]; then
   err "Usage: imp branch <description>"
   muted "Example: imp branch fix the login timeout bug"
   exit 1
fi

info "Suggesting branch name..."

name=$(ai_fast "Suggest a git branch name for: $desc

Rules:
- Lowercase, hyphens only, no spaces
- Max 30 chars
- Format: type/short-name
- Types: feat, fix, refactor, docs, test, chore

Output ONLY the branch name:")

name=$(echo "$name" | tr -d '[:space:]')

echo
echo "Suggested: $name"
echo

if confirm "Create branch?"; then
   git checkout -b "$name"
   success "Switched to $name"
else
   muted "Cancelled"
fi
