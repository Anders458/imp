#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

desc="$*"

# No args: interactive branch picker
if [[ -z "$desc" ]]; then
   header "Branches"

   branches=()
   labels=()

   while IFS= read -r line; do
      name=$(echo "$line" | sed 's/^[* ]*//' | xargs)
      [[ -z "$name" ]] && continue
      age=$(git log -1 --format='%cr' "$name" 2> /dev/null || echo "unknown")
      branches+=("$name")
      labels+=("$name  ($age)")
   done < <(git branch)

   if [[ ${#branches[@]} -le 1 ]]; then
      muted "Only one branch exists"
      exit 0
   fi

   choice=$(gum_choose "Switch to:" "${labels[@]}")
   target=$(echo "$choice" | sed 's/  (.*//')

   current=$(git branch --show-current)
   if [[ "$target" == "$current" ]]; then
      muted "Already on $target"
      exit 0
   fi

   require_clean
   git checkout "$target"
   success "Switched to $target"
   exit 0
fi

# With args: create branch from description
header "Branch"

name=$(spin "Generating name..." ai_fast "$(prompt_branch "$desc")")
name=$(echo "$name" | sanitize)

validate_branch "$name"

label "Suggested"
item "$name"
echo

if confirm "Create branch?"; then
   git checkout -b "$name"
   success "Switched to $name"
   hint "make changes, then imp commit"
else
   muted "Cancelled"
   exit 0
fi
