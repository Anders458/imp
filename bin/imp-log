#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Log"

count=20
ref=""

while [[ $# -gt 0 ]]; do
   case "$1" in
      -n)
         count="${2:-20}"
         shift 2
         ;;
      *)
         ref="$1"
         shift
         ;;
   esac
done

if [[ -n "$ref" ]]; then
   git log --oneline --graph --decorate --color=always -n "$count" "$ref"
else
   git log --oneline --graph --decorate --color=always -n "$count"
fi
