#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

stage_all=false
if [[ "${1:-}" == "-a" ]]; then
   stage_all=true
fi

if [[ "$stage_all" == "true" ]]; then
   git add -A
fi

diff=$(git diff --cached)

if [[ -z "$diff" ]]; then
   err "Nothing staged"
   hint "git add <files>, or imp commit -a"
   exit 1
fi

header "Commit"

branch=$(git branch --show-current 2> /dev/null || echo "")
msg=$(spin "Generating message..." ai_fast "$(prompt_commit "$diff" "$branch")")
msg=$(echo "$msg" | sanitize)

if ! validate_commit "$msg"; then
   warn "Retrying (invalid format)..."
   msg=$(spin "Generating message..." ai_fast "$(prompt_commit "$diff" "$branch")")
   msg=$(echo "$msg" | sanitize)

   if ! validate_commit "$msg"; then
      err "AI output not in Conventional Commits format"
      item "$msg"
      hint "imp commit, then edit manually"
      exit 1
   fi
fi

if ! confirm_commit "$msg"; then
   muted "Cancelled"
   exit 0
fi

success "Committed"
hint "imp commit again, or imp release when ready"
