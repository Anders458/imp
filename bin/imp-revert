#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Revert"

ref="${1:-}"

if [[ -z "$ref" ]]; then
   if [[ "$HAS_GUM" == "true" ]]; then
      # shellcheck disable=SC2046
      ref=$(gum choose --header "Select commit to revert" $(git log --oneline -10 2> /dev/null))
      ref="${ref%% *}"
   else
      show_items "Recent commits" "$(git log --oneline -10 2> /dev/null)"
      read -rp "Commit to revert (hash): " ref
   fi
   if [[ -z "$ref" ]]; then
      muted "Cancelled"
      exit 0
   fi
fi

if ! git rev-parse "$ref" &> /dev/null; then
   err "Invalid commit: $ref"
   exit 1
fi

commit_msg=$(git log -1 --pretty=%s "$ref")
commit_hash=$(git rev-parse --short "$ref")

label "Reverting"
item "$commit_hash $commit_msg"
echo

muted "Changes to undo:"
git diff "$ref~1..$ref" --stat 2> /dev/null | while read -r line; do
   item "$line"
done || git show --stat --format= "$ref" | while read -r line; do
   item "$line"
done
echo

if ! confirm "Create revert commit?" "n"; then
   muted "Cancelled"
   exit 0
fi

diff=$(git diff "$ref~1..$ref" 2> /dev/null | head -500 || git show --format= "$ref" | head -500)

msg=$(spin "Generating message..." ai_fast "$(prompt_revert "$commit_msg" "$diff")")

git revert --no-commit "$ref"

if ! confirm_commit "$msg"; then
   git revert --abort
   muted "Cancelled"
   exit 0
fi

success "Reverted $commit_hash"
hint "imp sync to push, or imp undo to cancel"
