#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Amend"

total=$(commit_count)
if [[ "$total" -eq 0 ]]; then
   err "No commits to amend"
   hint "imp commit first"
   exit 1
fi

last_msg=$(git log -1 --pretty=%s)

# Build diff without staging so we don't destroy the user's index on cancel
if [[ "$total" -eq 1 ]]; then
   combined=$(git show --format= HEAD)
   changes=$(git diff HEAD)
   [[ -n "$changes" ]] && combined="${combined}"$'\n'"${changes}"
else
   combined=$(git diff HEAD~1)
fi

if [[ -z "$combined" ]]; then
   err "Nothing to amend"
   exit 1
fi

msg=$(spin "Generating message..." ai_fast "$(prompt_commit "$combined")")

label "Previous"
item "$last_msg"
echo
label "New"

# Stage everything right before commit
git add -A

if ! confirm_commit "$msg" --amend; then
   muted "Cancelled"
   exit 0
fi

success "Amended"
hint "imp commit again, or imp release when ready"
