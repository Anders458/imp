#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Review"

if ! get_diff; then
   muted "No changes to review"
   exit 0
fi

review=$(spin "Reviewing $DIFF_CONTEXT..." ai_smart "$(prompt_review "$DIFF")")

divider
echo "$review" | md
divider

hint "imp commit to commit, or keep editing"
