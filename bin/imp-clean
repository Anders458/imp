#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Clean"

base=$(base_branch)
current=$(git branch --show-current)

spin "Fetching..." git fetch --prune

merged=$(
   git branch --merged "$base" \
      | sed 's/^[* ]*//' \
      | grep -v "^${base}$" \
      | grep -v "^${current}$" \
      || true
)

if [[ -z "$merged" ]]; then
   success "No merged branches to clean"
   exit 0
fi

label "Merged into $base"
echo "$merged" | while read -r b; do
   item "$b"
done
echo

count=$(echo "$merged" | wc -l | tr -d ' ')

if ! confirm "Delete $count branch(es)?"; then
   muted "Cancelled"
   exit 0
fi

echo
echo "$merged" | while read -r b; do
   git branch -d "$b"
   success "Deleted $b"

   if git ls-remote --heads origin "$b" 2> /dev/null | grep -q "$b"; then
      git push origin --delete "$b"
      success "Deleted remote $b"
   fi
done

echo
hint "imp branch to start something new"
