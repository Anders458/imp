#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git
require_jq

# Work from repo root so all paths are consistent
cd "$(git rev-parse --show-toplevel)"

# Collect ALL dirty files: staged + unstaged + untracked (deduplicated)
all_files=$(
   {
      git diff --cached --name-only
      git diff --name-only
      git ls-files --others --exclude-standard
   } | sort -u | sed '/^$/d'
)

count=$(echo "$all_files" | wc -l | tr -d ' ')

if [[ -z "$all_files" ]]; then
   err "No changes to split"
   hint "make some changes first"
   exit 1
fi

if [[ "$count" -eq 1 ]]; then
   err "Only 1 file changed"
   hint "use imp commit instead"
   exit 1
fi

header "Split"

show_items "Files ($count)" "$all_files"

# Build per-file diff snippets (truncated to ~30 lines)
file_diffs=""
while IFS= read -r f; do
   [[ -z "$f" ]] && continue

   local_diff=""
   if git ls-files --error-unmatch "$f" &> /dev/null; then
      local_diff=$(git diff HEAD -- "$f" 2> /dev/null || git diff --cached -- "$f" 2> /dev/null || true)
   fi

   # Untracked or new file: show first 30 lines as context
   if [[ -z "$local_diff" ]] && [[ -f "$f" ]]; then
      local_diff=$(head -30 "$f" 2> /dev/null | sed "s/^/+/" || true)
   fi

   if [[ -n "$local_diff" ]]; then
      snippet=$(echo "$local_diff" | head -30)
      file_diffs+="--- $f ---
$snippet
"
   else
      file_diffs+="--- $f --- (no diff available)
"
   fi
done <<< "$all_files"

branch=$(git branch --show-current 2> /dev/null || echo "")

# Validate AI response: JSON array, file coverage, commit messages
# Sets num_groups on success, exits on failure
validate_response() {
   local resp="$1"

   if ! echo "$resp" | jq empty 2> /dev/null; then
      err "AI returned invalid JSON"
      item "$resp"
      return 1
   fi

   if ! echo "$resp" | jq -e 'type == "array"' > /dev/null 2>&1; then
      err "AI response is not a JSON array"
      return 1
   fi

   num_groups=$(echo "$resp" | jq 'length')

   if [[ "$num_groups" -eq 0 ]]; then
      err "AI returned empty groups"
      return 1
   fi

   # Validate file coverage: every file appears exactly once
   local grouped_files expected_files

   grouped_files=$(echo "$resp" | jq -r '.[].files[]' | sort -u)
   expected_files=$(echo "$all_files" | sort -u)

   if [[ "$grouped_files" != "$expected_files" ]]; then
      err "File mismatch: AI groups don't cover all files"
      local missing extra

      missing=$(comm -23 <(echo "$expected_files") <(echo "$grouped_files"))
      extra=$(comm -13 <(echo "$expected_files") <(echo "$grouped_files"))
      [[ -n "$missing" ]] && show_items "Missing" "$missing"
      [[ -n "$extra" ]] && show_items "Extra" "$extra"
      return 1
   fi

   # Validate each commit message
   local i msg

   for i in $(seq 0 $((num_groups - 1))); do
      msg=$(echo "$resp" | jq -r ".[$i].message")
      if ! validate_commit "$msg"; then
         err "AI output not in Conventional Commits format"
         item "$msg"
         return 1
      fi
   done
}

response=$(spin "Analyzing changes..." ai_smart "$(prompt_split "$file_diffs" "$branch")")
response=$(echo "$response" | sed '/^```/d')

if ! validate_response "$response"; then
   warn "Retrying..."
   response=$(spin "Re-analyzing..." ai_smart "$(prompt_split "$file_diffs" "$branch")")
   response=$(echo "$response" | sed '/^```/d')

   if ! validate_response "$response"; then
      exit 1
   fi
fi

# Handle single group: hint to use imp commit instead
if [[ "$num_groups" -eq 1 ]]; then
   warn "AI grouped everything into a single commit"
   hint "use imp commit instead"
   exit 0
fi

# Display groups for confirmation
echo
for i in $(seq 0 $((num_groups - 1))); do
   msg=$(echo "$response" | jq -r ".[$i].message")
   files=$(echo "$response" | jq -r ".[$i].files[]")
   label "Group $((i + 1)): $msg"
   echo "$files" | while IFS= read -r f; do
      item "$f"
   done
   echo
done

if ! confirm "Commit $num_groups groups?"; then
   muted "Cancelled"
   exit 0
fi

# Save HEAD for rollback
original_head=$(git rev-parse HEAD)

rollback() {
   echo
   warn "Rolling back..."
   git reset --soft "$original_head" 2> /dev/null || true
   git reset HEAD 2> /dev/null || true
   err "Split failed"
   exit 1
}

trap rollback ERR

# Stage everything first
git add -A

for i in $(seq 0 $((num_groups - 1))); do
   msg=$(echo "$response" | jq -r ".[$i].message")

   # Reset staging area without touching working tree
   git reset HEAD > /dev/null 2>&1

   # Stage only this group's files
   while IFS= read -r f; do
      git add -- "$f"
   done < <(echo "$response" | jq -r ".[$i].files[]")

   git commit -m "$msg" > /dev/null
   success "Group $((i + 1)): $msg"
done

trap - ERR

hint "imp log to review"
